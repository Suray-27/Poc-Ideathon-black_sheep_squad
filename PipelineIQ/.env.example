# Database Configuration
DATABASE_PATH=data/source_warehouse.db

# Folder scanned for external source files (CSV/JSON/Excel), relative to the project root
SOURCES_DIR=data/sources

# Application Settings
DEBUG=True
LOG_LEVEL=INFO

# Self-healing: how many times to re-ask the model to repair a failing pipeline
MAX_REPAIR_ATTEMPTS=3

# API Keys (never commit actual keys, use .env instead)
# Get a key from https://aistudio.google.com/apikey (it starts with "AQ.")
GEMINI_API_KEY=your_key_here
